\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Training Time Trajectory. Total wall-clock training time (seconds) for each model across six paradigm-complexity stages. The transition from centralized to federated multi-task settings introduces a 2.4--3.9$\times $ overhead driven by communication and synchronization costs. LoRA substantially reduces federated training time by limiting parameter transmission volume.}}{8}{figure.caption.7}\protected@file@percent }
\newlabel{fig:time_trajectory}{{4}{8}{Training Time Trajectory. Total wall-clock training time (seconds) for each model across six paradigm-complexity stages. The transition from centralized to federated multi-task settings introduces a 2.4--3.9$\times $ overhead driven by communication and synchronization costs. LoRA substantially reduces federated training time by limiting parameter transmission volume}{figure.caption.7}{}}
